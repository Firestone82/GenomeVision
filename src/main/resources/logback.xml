<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <conversionRule conversionWord="coloredText"
                    converterClass="cz.mik0486.semestralproject.utils.log.ColoredHighlightingText"/>

    <conversionRule conversionWord="coloredType"
                    converterClass="cz.mik0486.semestralproject.utils.log.ColoredHighlightingType"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%white%d{yyyy-MM-dd HH:mm:ss} | %coloredType(%-5(%level)) | %cyan(%logger{10}) : %coloredText(%msg%n)</pattern>
            <charset>utf-8</charset>
        </encoder>
    </appender>

    <root level="TRACE">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
